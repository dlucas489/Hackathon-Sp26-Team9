# ============================================================================
# CREDENTIALS — Copy this file to .env and fill in your credentials
# ============================================================================

# NOAA Global Summary of the Day API
# Get key: https://www.ncei.noaa.gov/cdo-web/token
NOAA_API_KEY=your_noaa_key_here

# USDA QuickStats API (if needed)
# Get key: https://quickstats.nass.usda.gov/api
USDA_API_KEY=your_usda_key_here

# NASA Earthdata (for satellite data access)
# Account: https://earthdata.nasa.gov
EARTHDATA_USERNAME=your_nasa_username
EARTHDATA_PASSWORD=your_nasa_password

# AWS SageMaker (only if running 03_satellite_fixed on SageMaker)
# Note: IAM credentials are auto-provisioned in SageMaker; this is optional
AWS_REGION=us-west-2